---
	import Layout from '../layouts/Layout.astro';
	import Header from '../components/Header.astro';
	import Contact from '../components/Contact.astro';
	import Footer from '../components/Footer.astro';

	import ItemsToEngrave from '../assets/images/engraveable-withLogo.jpg'
	import ItemsToEngrave1 from '../assets/images/laser-item-options.jpg'
	import ItemsToEngrave2 from '../assets/images/christmas-decor.jpg'
---

<Layout>
	<Header />

	<section class="hero">
		<div class="small-wrapper hero-container">
			<div class="text-container">
				<h1>Laser engraving, turning items to something unique and personal</h1>
				<p>Transform your favorite items with precision laser engraving. From tumblers and wallets to tools, gifts, and business products, we help you create personalized pieces that leave a lasting impression.</p>

				<div class="cta-container">
					<a href="/#contact" class="main-cta" title="Request a quote" aria-label="Request a quote link">
						<span>Request a quote</span>
					</a>
					<a href="/#about" class="secondary-cta learnMore-cta" title="Learn More" aria-label="Learn More link">
						Learn More
					</a>
				</div>
			</div>
			<div class="showCase-images"></div>
		</div>
	</section>

	<section id="services" class="section-padding">
		<div class="small-wrapper services-container">
			<h2>Services</h2>
			<p class="section-introP">
				 Whether you're creating a meaningful gift, adding professional branding, or customizing an item you already own, we provide quality laser engraving tailored to your needs. We work with a variety of materials and products to help transform everyday items into something truly unique.
			</p>

			<div class="services-row row1">
				<div class="col text-content">
					<h3>Bring in your items and we'll help make it one of a kind.</h3>

					<ul>
						<li>Tumblers & Drinkware</li>
						<li>Water Bottles</li>
						<li>Pocket Knives</li>
						<li>Multi-Tools</li>
						<li>Leather Wallets</li>
						<li>Journals & Notebooks</li>
						<li>Key chains</li>
						<li>Gift Items</li>
						<li>Personal Keepsakes</li>
					</ul>
				</div>
				<div class="col image-col"></div>
			</div>

			<p>Great for business and promotional products but not limited to personalized gifts. Adding names, dates, meaningful messages, monograms, or custom artwork. Make your brand or message stand out with professionally engraved products.</p>

			<div class="services-row row2">
				<ul>
					<li>Birthdays</li>
					<li>Weddings</li>
					<li>Anniversaries</li>
					<li>Graduations</li>
					<li>Father's Day</li>
					<li>Mother's Day</li>
					<li>Retirement Gifts</li>
				</ul>
				<ul>
					<li>Employee Appreciation Gifts</li>
					<li>Client Thank You Gifts</li>
					<li>Promotional Products</li>
					<li>Corporate Events</li>
					<li>Small Business Branding</li>
					<li>Team Recognition Items</li>
					<li>Holiday Gifts</li>
				</ul>
			</div>

			<div class="row3">
				<figure class="col">
					<img src={ItemsToEngrave1.src} alt="" class="pics">
				</figure>
				<figure class="col">
					<img src={ItemsToEngrave2.src} alt="" class="pics">
				</figure>
			</div>

			<a href="/#contact" class="main-cta readyToStart-cta" title="Ready to Start Personalizing?" aria-label="Ready to Start Personalizing?">
				<span>Ready to Start Personalizing?</span>
			</a>

		</div>
	</section>

	<section id="how-it-works" class="section-padding">
		<div class="small-wrapper howItWorks-container">
			<div class="col col1">
				<h2>How It Works</h2>
			</div>
			<div class="col col2">
				<ul>
					<li>
						<h4>1. Contact Us</h4>
						<p> Tell us about your item and engraving idea.</p>
					</li>
					<li>
						<h4>2. Review & Quote</h4>
						<p>We review your project and provide pricing and turnaround information.</p>
					</li>
					<li>
						<h4>3. Engraving Begins</h4>
						<p>Your design is prepared and engraved with attention to detail.</p>
					</li>
					<li>
						<h4>4. Pickup or Delivery</h4>
						<p>Receive your finished personalized item and enjoy something uniquely yours.</p>
					</li>
				</ul>
			</div>
		</div>
	</section>

	<Contact />

	<section id="faq" class="section-padding">
		<div class="small-wrapper faq-container">
			<h2>FAQs</h2>
			
			<div class="faq-item">
				<button class="faq-question">
					<span>What items can be engraved?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						We can engrave a wide variety of items including tumblers,
						water bottles, knives, cutting boards, coasters, leather
						goods, keychains, ornaments, notebooks, tools, and more.
					</p>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-question">
					<span>What can be engraved on my item?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						Names, logos, artwork, monograms, quotes, dates, custom
						designs, QR codes, and more depending on the material and
						engraving area available.
					</p>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-question">
					<span>Can I bring my own item?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						Yes. Customer supplied items are welcome. We will review the
						item beforehand to ensure it is suitable for laser engraving.
					</p>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-question">
					<span>How long does an order take?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						Turnaround times vary depending on quantity and complexity,
						but most orders are completed within 3–7 business days.
					</p>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-question">
					<span>Do you offer bulk or business orders?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						Yes. We provide custom engraving for corporate gifts,
						promotional products, employee recognition items, and event
						giveaways.
					</p>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-question">
					<span>How do I get a quote?</span>
					<span class="faq-icon"></span>
				</button>
				<div class="faq-answer">
					<p>
						Contact us by filling out the contact form or email, with a description of your item, quantity, and
						engraving design. We will provide a custom quote based on your project requirements.
					</p>
					<a class="main-cta" href="mailto:lopantzilaserstudio@gmail.com" style="margin-bottom: 1.75rem;" title="lopantzilaserstudio@gmail.com" aria-label="Email link, lopantzilaserstudio@gmail.com">
						<span>email</span>
					</a>
				</div>
			</div>
		</div>
	</section>
	
	<Footer />
</Layout>
<style>
	.hero{
		height: 800px;
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.hero-container .text-container{
		height: 50%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
	}
	.text-container h1{
		font-size: 4rem;
		margin-bottom: 3rem;
		text-align: center;
	}
	.text-container p{
		font-size: 1.25rem;
		text-align: center;
	}
	.hero-container .cta-container{
		margin-top: 3rem;
		display: flex;
		gap: 0 1.75rem;
		align-items: center;
	}
	.hero-container .learnMore-cta::after{content: 'Learn More';}

	/* SERVICES SECTION */
	#services{
		background-color: var(--black);
		color: var(--cream);
	}
	#services h2,
	#services p{text-align: center;}
	.services-row{
		display: flex;
		justify-content: space-evenly;
		margin: 4.5rem 0;
	}
	.services-row .col{width: 42%;}
	.services-row .text-content{
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.services-row .text-content h3{margin-bottom: 1.125rem;}
	.services-row .text-content ul,
	.row2 ul li{
		list-style: circle;
		margin-left: 18px;
	}

	.services-row .text-content ul li,
	.row2 ul li{margin-bottom: 10px;}

	.services-row .text-content ul li:last-child,
	.row2 ul li:last-child{margin-bottom: 0;}
	.row1, .row3{height: 400px;}

	.row1 .image-col{
		height: auto;
		background-image: url(../assets/images/engraveable-withLogo.jpg);
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}
	.row3{
		display: flex;
		justify-content: space-evenly;
	}
	.row3 .col{width: 42%;}
	.readyToStart-cta{
		max-width: 300px;
		margin: 4rem auto 0 auto;
	}
	.readyToStart-cta::after{content:'Ready to Start Personalizing?';}

	/* HOW IT WORKS SECTION */
	#how-it-works{
		background-color: var(--orange);
		color: #fff;
		/* color: var(--cream); */
	}
	.howItWorks-container{
		display: flex;
		justify-content: space-evenly;
	}
	.howItWorks-container .col{
		width: 42%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.howItWorks-container .col2 ul li{margin-bottom: 1.25rem;}
	.howItWorks-container .col2 ul li:last-child{margin-bottom: 0;}

	/* FAQ SECTION */
	#faq{
		background-color: var(--black);
		color: var(--cream);
	}
	.faq-container h2{
		text-align: center;
		margin-bottom: 4rem;
	}
	.faq-item{
		border-bottom: 1px solid var(--cream);
	}
	.faq-question{
		width: 100%;
		background: transparent;
		border: none;
		color: var(--cream);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 2.5rem 0;
		cursor: pointer;
		font-size: 1.25rem;
		font-weight: bold;
		text-align: left;
	}
	.faq-icon{
		width: 18px;
		height: 18px;
		border-right: 2px solid var(--cream);
		border-bottom: 2px solid var(--cream);
		transform: rotate(45deg);
		transition: transform 0.3s ease;
		flex-shrink: 0;
	}
	.faq-item.active .faq-icon{ transform: rotate(-135deg); }
	.faq-answer{
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.35s ease;
	}
	.faq-answer p{
		padding: 0 0 1.5rem;
		color: var(--cream);
		line-height: 1.7;
	}


	@media (max-width: 921px) {
		.hero{margin-top: 120px;}
		.text-container h1{font-size: 3.5rem;}

		.row1, .row3{height: auto;}
		.services-row .col,
		.row3 .col,
		.howItWorks-container .col{width: 100%;}
		.row1 .image-col{
			height: 350px;
			margin-top: 3rem;
		}
		.services-row,
		.row3, 
		.howItWorks-container{flex-direction: column;}
		.services-row h3{text-align: center;}
		.row2 ul:first-of-type{margin-bottom: 1rem;}
		.row3 figure:first-of-type,
		.howItWorks-container h2{margin-bottom: 3rem;}

		{flex-direction: column;}
	}
	@media screen and (max-width: 768px) {
		.faq-question{
			font-size: 1rem;
			padding: 2rem 0;
		}
		.faq-icon{
			width: 14px;
			height: 14px;
		}
	}
	@media screen and (max-width: 480px){
		.hero{height: 700px;}
		.text-container h1{font-size: 3.25rem;}
		.cta-container{
			width: 100%;
			flex-direction: column;
		}
		.cta-container a:first-of-type{margin-bottom: 2rem;}
		.readyToStart-cta{
			max-width: none;
			width: 100%;
		}
	}
</style>

<script>
	const faqItems = document.querySelectorAll('.faq-item');

	faqItems.forEach(item => {
		const button = item.querySelector('.faq-question');
		const answer = item.querySelector('.faq-answer');

		button.addEventListener('click', () => {
			const isOpen = item.classList.contains('active');

			faqItems.forEach(faq => {
				faq.classList.remove('active');
				faq.querySelector('.faq-answer').style.maxHeight = null;
			});

			if (!isOpen) {
				item.classList.add('active');
				answer.style.maxHeight = answer.scrollHeight + 'px';
			}
		});
	});
</script>