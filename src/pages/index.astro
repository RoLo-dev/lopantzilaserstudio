---
	import Layout from '../layouts/Layout.astro';
	import Header from '../components/Header.astro';
	import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />

	<section class="hero">
		<div class="small-wrapper hero-container">
			<div class="text-container">
				<h1>Custom Laser Engraving That Makes Every Item Unique</h1>
				<p>Transform your favorite items with precision laser engraving. From tumblers and wallets to tools, gifts, and business products, Lopantzi Laser Studio helps you create personalized pieces that leave a lasting impression.</p>

				<div class="cta-container">
					<a href="/#contact" class="main-cta" title="Request a quote">
						<span>Request a quote</span>
					</a>
					<a href="/#about" class="secondary-cta LearnMore-cta" title="Learn More">Learn More</a>
				</div>
			</div>
			<div class="showCase-images"></div>
		</div>
	</section>

	<section class="about">
		<div class="small-wrapper about-container">

		</div>
	</section>
	
	<Footer />
</Layout>
<style>
	.hero{
		height: 800px;
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.hero-container .text-container{
		height: 50%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
	}
	.text-container h1{
		font-size: 4.5rem;
		margin-bottom: 3rem;
		text-align: center;
	}
	.text-container p{
		font-size: 1.25rem;
		text-align: center;
	}
	.hero-container .cta-container{
		margin-top: 3rem;
		display: flex;
		gap: 0 1.75rem;
		align-items: center;
	}
	.hero-container .learnMore-cta::after{content: 'Learn More';}
</style>